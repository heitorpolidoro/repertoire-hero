#!/usr/bin/env bash
# run — Inicia o ambiente de desenvolvimento do Repertoire Hero
#
# O que faz:
#   1. Garante que o container postgres do workspace (~/workspace) está rodando
#   2. Roda as migrations do banco se necessário
#   3. Inicia o servidor Next.js em modo dev (com hot reload)
#
# Uso:
#   ./run              → sobe tudo
#   ./run --no-migrate → pula as migrations

set -euo pipefail

WORKSPACE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$WORKSPACE_DIR/docker-compose.yml"
POSTGRES_PORT=5432
SKIP_MIGRATE=false

# Parse args
for arg in "$@"; do
  case $arg in
    --no-migrate) SKIP_MIGRATE=true ;;
    -h|--help)
      echo "Usage: ./run [--no-migrate]"
      exit 0
      ;;
  esac
done

# ── Cores ─────────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

info()    { echo -e "${CYAN}▶ $*${RESET}"; }
success() { echo -e "${GREEN}✔ $*${RESET}"; }
warn()    { echo -e "${YELLOW}⚠ $*${RESET}"; }

# ── 1. Garantir que o postgres está rodando ────────────────────────────────────
info "Verificando postgres na porta $POSTGRES_PORT..."

postgres_running() {
  docker compose -f "$COMPOSE_FILE" ps --status running postgres 2>/dev/null | grep -q "postgres"
}

if postgres_running; then
  success "Postgres já está rodando."
else
  warn "Postgres não está rodando. Subindo via docker compose do workspace..."
  docker compose -f "$COMPOSE_FILE" up -d postgres

  info "Aguardando postgres ficar saudável..."
  until docker compose -f "$COMPOSE_FILE" exec -T postgres pg_isready -U postgres -q 2>/dev/null; do
    sleep 1
  done
  success "Postgres pronto."
fi

# ── 2. Garantir que o database existe ─────────────────────────────────────────
info "Garantindo que o database 'repertoire_hero' existe..."
docker compose -f "$COMPOSE_FILE" exec -T postgres \
  psql -U postgres -tc "SELECT 1 FROM pg_database WHERE datname='repertoire_hero'" \
  | grep -q 1 \
  || docker compose -f "$COMPOSE_FILE" exec -T postgres \
     psql -U postgres -c "CREATE DATABASE repertoire_hero;"
success "Database pronto."

# ── 3. Migrations ─────────────────────────────────────────────────────────────
if [ "$SKIP_MIGRATE" = false ]; then
  info "Rodando migrations..."
  (cd "$PROJECT_DIR" && npm run db:migrate)
  success "Migrations aplicadas."
else
  warn "Pulando migrations (--no-migrate)."
fi

# ── 4. Iniciar Next.js dev ─────────────────────────────────────────────────────
echo ""
success "Iniciando servidor de desenvolvimento em http://127.0.0.1:3000"
echo -e "  ${CYAN}Hot reload:${RESET} ativo para componentes React e rotas Next.js"
echo -e "  ${CYAN}Reinício manual:${RESET} necessário para mudanças em .env e next.config.ts"
echo ""

exec npm run dev
