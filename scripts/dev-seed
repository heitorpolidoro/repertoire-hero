#!/usr/bin/env bash
# =============================================================================
# scripts/dev-seed
#
# Resets and seeds the local development database with a clean set of users.
#
# Inserts Better Auth user + account rows and matching profiles directly via
# psql — no running dev server required.
#
# Usage:
#   bash scripts/dev-seed [DATABASE_URL]
#
# Default DATABASE_URL: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Password for all dev users: password
# =============================================================================

set -euo pipefail

DB_URL="${1:-${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres}}"

# Hash of "password" generated by @better-auth/utils hashPassword (scrypt).
# To regenerate: node --input-type=module -e "
#   import { hashPassword } from './node_modules/@better-auth/utils/dist/password.mjs';
#   console.log(await hashPassword('password'));
# "
PASSWORD_HASH="833c3aea9353e3ea3c6a0fec1eee721c:372df83d18e5b0f95107817d5c2e3e0191c4fbf5b69b9bd9f3b24f0c2ca6d629907f098fea0d3fe5245b7a81c298b1c177be80e4eeae75c8d3dd658eb8ab992f"

echo "🌱 Seeding dev database ($DB_URL)..."
echo ""

psql "$DB_URL" <<SQL

-- ── Clean slate ─────────────────────────────────────────────────────────────
-- Deleting from "user" cascades to: account, session, profiles,
-- then profiles cascades to: band_members, repertoire, playlists.
-- Delete bands separately (no longer FK'd to user/profiles).
DELETE FROM bands;
DELETE FROM "user";

-- ── Users (Better Auth) ─────────────────────────────────────────────────────
INSERT INTO "user" (id, email, name, "emailVerified", "createdAt", "updatedAt")
VALUES
  (gen_random_uuid(), 'com.spotify@exemple.com', 'Com Spotify', true, now(), now()),
  (gen_random_uuid(), 'sem_spotify@exemple.com', 'Sem Spotify', true, now(), now()),
  (gen_random_uuid(), 'sem_banda@exemple.com',   'Sem Banda',   true, now(), now());

-- ── Credentials ─────────────────────────────────────────────────────────────
INSERT INTO "account" (id, "accountId", "providerId", "userId", password, "createdAt", "updatedAt")
SELECT gen_random_uuid(), u.email, 'credential', u.id, '$PASSWORD_HASH', now(), now()
FROM "user" u;

-- ── Profiles ─────────────────────────────────────────────────────────────────
INSERT INTO profiles (id, email, full_name, instruments, primary_instrument)
SELECT
  u.id,
  u.email,
  u.name,
  CASE u.email
    WHEN 'com.spotify@exemple.com' THEN ARRAY['Bass Guitar', 'Backing Vocals']
    WHEN 'sem_spotify@exemple.com' THEN ARRAY['Drums', 'Guitar']
    WHEN 'sem_banda@exemple.com'   THEN ARRAY['Piano', 'Saxophone']
  END,
  CASE u.email
    WHEN 'com.spotify@exemple.com' THEN 'Bass Guitar'
    WHEN 'sem_spotify@exemple.com' THEN 'Drums'
    WHEN 'sem_banda@exemple.com'   THEN 'Piano'
  END
FROM "user" u;

-- ── Band: Os Dois Spotify ────────────────────────────────────────────────────
INSERT INTO bands (name, description)
VALUES ('Os Dois Spotify', 'Banda de dev com os usuários Spotify');

INSERT INTO band_members (band_id, user_id, role)
SELECT b.id, p.id, 'admin'  FROM bands b, profiles p
WHERE b.name = 'Os Dois Spotify' AND p.email = 'com.spotify@exemple.com';

INSERT INTO band_members (band_id, user_id, role)
SELECT b.id, p.id, 'member' FROM bands b, profiles p
WHERE b.name = 'Os Dois Spotify' AND p.email = 'sem_spotify@exemple.com';

-- ── Summary ──────────────────────────────────────────────────────────────────
SELECT u.email, p.full_name, p.primary_instrument, p.instruments
FROM "user" u JOIN profiles p ON p.id = u.id
ORDER BY u.email;

SELECT b.name AS band, bm.role, p.full_name
FROM bands b
JOIN band_members bm ON bm.band_id = b.id
JOIN profiles p ON p.id = bm.user_id
ORDER BY b.name, bm.role DESC;

SQL

echo ""
echo "✅ Done. Password for all users: password"
